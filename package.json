{
  "name": "skill-forge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "skills/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "generate": "bun scripts/generate-installers.ts",
    "generate:check": "bun scripts/generate-installers.ts --check",
    "install:all": "bun run --filter 'skills/*' install:skill"
  }
}
